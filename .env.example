# CrewForge configuration. Copy to `.env` and adjust as needed.

# Base URL of the local Ollama HTTP API.
OLLAMA_BASE_URL=http://localhost:11434

# Default Ollama model tag used by any agent/role that doesn't pin its own.
DEFAULT_MODEL=qwen2.5:7b

# Ollama embedding model used for crew memory.
EMBED_MODEL=nomic-embed-text

# Per-request timeout (seconds) for Ollama calls. Generation can be slow locally.
REQUEST_TIMEOUT=300

# Override config/data locations if you don't want the repo defaults.
# CONFIG_DIR=./config
# DATA_DIR=./data
